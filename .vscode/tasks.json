		{
			"label": "analyze-duplicate-japanese-words",
			"type": "shell",
			"command": "py -3 -c \"import re,collections,pathlib; t=pathlib.Path('data.js').read_text(encoding='utf-8'); p=re.compile(r'id:\\s*\\\"D(\\\\d{2})-W\\\\d{2}\\\"[^\\\\n]*?type:\\s*\\\"word\\\"[^\\\\n]*?japanese:\\s*\\\"([^\\\"]+)\\\"[^\\\\n]*?answer:\\s*\\\"([^\\\"]+)\\\"'); g=collections.defaultdict(set); [g[j].add(a.strip().lower()) for d,j,a in p.findall(t) if 1<=int(d)<=40]; rows=sorted((j,sorted(v)) for j,v in g.items() if len(v)>=2); print('COUNT',len(rows)); [print(j+'\\t'+' | '.join(v)) for j,v in rows]\"",
			"isBackground": false,
			"group": "build"
		},
